# Public app base URL used by browser redirects and links.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase project URL (safe for client-side use).
NEXT_PUBLIC_SUPABASE_URL=

# Supabase publishable key (recommended client key).
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# For hosted Supabase, set the auth email sender display name in Authentication -> Email -> Sender details.
# Use "WhereYouRank" as the sender name until a custom email domain is configured.

# Supabase anon legacy JWT key (optional backward compatibility).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key (server only, bypasses RLS for backend jobs).
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection string for migrations/jobs.
DATABASE_URL=

# Supabase Storage bucket name for raw uploaded WHOOP CSV files.
SUPABASE_STORAGE_BUCKET_RAW=whoop-raw-uploads

# JWT signing secret used by Supabase auth verification on server.
SUPABASE_JWT_SECRET=

# OpenAI API key used for AI interpretation layer.
OPENAI_API_KEY=

# OpenAI model identifier for answer generation.
OPENAI_MODEL=gpt-4.1-mini

# Default minimum cohort sample size for general benchmark surfaces.
# The current "How you compare so far" section uses its own server-side min_n policy.
COHORT_MIN_SAMPLE_SIZE=50

# Default analytics window used by dashboard and AI when user does not specify one.
DEFAULT_ANALYTICS_WINDOW=last_30d

# Soft operational target for completing delete-my-data requests (hours).
DELETE_REQUEST_MAX_HOURS=24

# Hard compliance limit for completing deletion requests (days).
DELETE_REQUEST_HARD_LIMIT_DAYS=30

# Shared secret required to trigger protected cron/background endpoints.
CRON_SECRET=

# Cron schedule for full analytics rebuild safety job (UTC).
ANALYTICS_REBUILD_SCHEDULE=0 2 * * *

# Application log verbosity level: debug | info | warn | error.
LOG_LEVEL=info
